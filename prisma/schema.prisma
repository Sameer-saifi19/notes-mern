
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User{
  id    String @id @default(uuid())
  name  String  
  email  String @unique
  image String?
  notes  Note[]

  @@map("user")
}

model Note{
  id   String @id @default(cuid())
  title String
  description String
  userId  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user  User @relation(fields: [userId], references: [id])
}